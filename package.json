{
  "name": "vibecoding-starter",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "packageManager": "bun@1.3.5",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "bootstrap": "bash ./scripts/bootstrap-local.sh",
    "dev": "turbo run dev --parallel",
    "dev:stack": "bash ./scripts/compose.sh up -d",
    "dev:web": "turbo run dev --filter=@vibecoding-starter/web",
    "dev:api": "turbo run dev --filter=@vibecoding-starter/api",
    "dev:worker": "turbo run dev --filter=@vibecoding-starter/worker",
    "stack:up": "bash ./scripts/compose.sh up -d",
    "stack:down": "bash ./scripts/compose.sh down",
    "stack:logs": "bash ./scripts/compose.sh logs -f postgres redis",
    "stack:ps": "bash ./scripts/compose.sh ps",
    "stack:reset": "bash ./scripts/compose.sh down -v",
    "session:status": "node ./scripts/start-session.mjs",
    "build": "turbo run build",
    "openapi:generate": "bun apps/api/scripts/generate-openapi.ts",
    "prisma:generate": "cd apps/api && bun run prisma:generate",
    "prisma:migrate:dev": "cd apps/api && bun run prisma:migrate:dev",
    "prisma:seed": "cd apps/api && bun run prisma:seed",
    "prisma:studio": "cd apps/api && bun run prisma:studio",
    "start:web": "turbo run start --filter=@vibecoding-starter/web",
    "start:api": "turbo run start --filter=@vibecoding-starter/api",
    "start:worker": "turbo run start --filter=@vibecoding-starter/worker",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:smoke": "turbo run test:smoke",
    "check": "bun run skills:validate && bun run lint && bun run typecheck && bun run test && bun run test:smoke && bun run build",
    "skills:create": "node .agents/scripts/create-skill.mjs",
    "skills:sync": "bun run skills:sync-registry && bun run skills:sync-claude",
    "skills:sync-claude": "node .agents/scripts/sync-claude-skills.mjs",
    "skills:sync-registry": "node .agents/scripts/sync-skill-registry.mjs",
    "skills:validate": "node .agents/scripts/validate-skills.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.6.3"
  }
}
