    "react-date-picker": "^12.0.1",
    "react-dom": "^19.2.4",
    "react-filepond": "^7.1.3",
    "react-select": "^5.10.2",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.14.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
