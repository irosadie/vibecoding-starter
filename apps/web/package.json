{
  "name": "@vibecoding-starter/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "biome check app auth.ts auth.test.ts components configs constants hooks next.config.ts providers proxy.ts services tailwind.config.ts test types utils vitest.config.ts",
