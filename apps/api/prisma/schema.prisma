generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                          String               @id @default(uuid()) @db.Uuid
  email                       String               @unique @db.VarChar(255)
  passwordHash                String               @map("password_hash") @db.Text
  name                        String               @db.VarChar(120)
  role                        UserRole             @default(USER)
  status                      UserStatus           @default(ACTIVE)
  photo                       String?              @db.Text
  createdAt                   DateTime             @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                   DateTime             @updatedAt @map("updated_at") @db.Timestamp(6)
  authSessions                AuthSession[]
  creatorApplications         CreatorApplication[] @relation("CreatorApplicationUser")
  reviewedCreatorApplications CreatorApplication[] @relation("CreatorApplicationReviewer")
  createdExams                Exam[]               @relation("ExamCreator")
  reviewedExamVersions        ExamVersion[]        @relation("ExamVersionReviewer")
  examReviewLogs              ExamReviewLog[]      @relation("ExamReviewLogActor")
  creatorProfile              CreatorProfile?
  commerceCartItems           CommerceCartItem[]
  commerceOrders              CommerceOrder[]
  commerceOwnerships          CommerceOwnership[]

  @@map("users")
}

model AuthSession {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.Text
  expiresAt DateTime @map("expires_at") @db.Timestamp(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("auth_sessions")
}

model CreatorApplication {
  id                  String                   @id @default(uuid()) @db.Uuid
  userId              String                   @map("user_id") @db.Uuid
  ktpFileUrl          String                   @map("ktp_file_url") @db.Text
  payoutAccountName   String                   @map("payout_account_name") @db.VarChar(255)
  payoutBankName      String                   @map("payout_bank_name") @db.VarChar(100)
  payoutAccountNumber String                   @map("payout_account_number") @db.VarChar(100)
  status              CreatorApplicationStatus @default(PENDING)
  submittedAt         DateTime                 @map("submitted_at") @db.Timestamp(6)
  reviewedBy          String?                  @map("reviewed_by") @db.Uuid
  reviewedAt          DateTime?                @map("reviewed_at") @db.Timestamp(6)
  reviewNote          String?                  @map("review_note") @db.Text
  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime                 @updatedAt @map("updated_at") @db.Timestamp(6)

  user     User  @relation("CreatorApplicationUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("CreatorApplicationReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
  @@map("creator_applications")
}

model CreatorProfile {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @unique @map("user_id") @db.Uuid
  payoutAccountName   String   @map("payout_account_name") @db.VarChar(255)
  payoutBankName      String   @map("payout_bank_name") @db.VarChar(100)
  payoutAccountNumber String   @map("payout_account_number") @db.VarChar(100)
  approvedAt          DateTime @map("approved_at") @db.Timestamp(6)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("creator_profiles")
}

model Exam {
  id               String          @id @default(uuid()) @db.Uuid
  creatorId        String          @map("creator_id") @db.Uuid
  slug             String          @unique @db.VarChar(255)
  title            String          @db.VarChar(255)
  category         String          @db.VarChar(100)
  level            ExamLevel
  shortDescription String          @map("short_description") @db.VarChar(255)
  description      String          @db.Text
  durationMinutes  Int             @map("duration_minutes")
  currentStatus    ExamDraftStatus @default(DRAFT) @map("current_status")
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamp(6)

  creator  User          @relation("ExamCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  versions ExamVersion[]

  @@index([creatorId])
  @@index([currentStatus])
  @@index([updatedAt])
  @@map("exams")
}

model ExamVersion {
  id               String            @id @default(uuid()) @db.Uuid
  examId           String            @map("exam_id") @db.Uuid
  versionNumber    Int               @map("version_number")
  status           ExamVersionStatus @default(DRAFT)
  metadataSnapshot Json              @map("metadata_snapshot")
  submittedAt      DateTime?         @map("submitted_at") @db.Timestamp(6)
  reviewedBy       String?           @map("reviewed_by") @db.Uuid
  reviewedAt       DateTime?         @map("reviewed_at") @db.Timestamp(6)
  reviewNote       String?           @map("review_note") @db.Text
  publishedAt      DateTime?         @map("published_at") @db.Timestamp(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamp(6)

  exam       Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  reviewer   User?           @relation("ExamVersionReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  questions  ExamQuestion[]
  reviewLogs ExamReviewLog[]

  @@unique([examId, versionNumber])
  @@index([status])
  @@index([submittedAt])
  @@map("exam_versions")
}

model ExamQuestion {
  id                  String                @id @default(uuid()) @db.Uuid
  examVersionId       String                @map("exam_version_id") @db.Uuid
  orderNumber         Int                   @map("order_number")
  prompt              String                @db.Text
  optionA             String                @map("option_a") @db.Text
  optionB             String                @map("option_b") @db.Text
  optionC             String                @map("option_c") @db.Text
  optionD             String                @map("option_d") @db.Text
  correctOption       QuestionCorrectOption @map("correct_option")
  explanationText     String?               @map("explanation_text") @db.Text
  explanationVideoUrl String?               @map("explanation_video_url") @db.Text
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime              @updatedAt @map("updated_at") @db.Timestamp(6)

  examVersion ExamVersion @relation(fields: [examVersionId], references: [id], onDelete: Cascade)

  @@unique([examVersionId, orderNumber])
  @@index([examVersionId])
  @@map("exam_questions")
}

model ExamReviewLog {
  id            String           @id @default(uuid()) @db.Uuid
  examVersionId String           @map("exam_version_id") @db.Uuid
  actorId       String           @map("actor_id") @db.Uuid
  action        ExamReviewAction
  note          String?          @db.Text
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamp(6)

  examVersion ExamVersion @relation(fields: [examVersionId], references: [id], onDelete: Cascade)
  actor       User        @relation("ExamReviewLogActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([examVersionId])
  @@index([actorId])
  @@map("exam_review_logs")
}

model ExamProduct {
  id               String    @id @default(uuid()) @db.Uuid
  slug             String    @unique @db.VarChar(255)
  title            String    @db.VarChar(255)
  category         String    @db.VarChar(100)
  level            ExamLevel
  shortDescription String    @map("short_description") @db.Text
  description      String    @db.Text
  priceAmount      Int       @map("price_amount")
  isPublished      Boolean   @default(true) @map("is_published")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamp(6)

  @@index([isPublished])
  @@index([category])
  @@index([level])
  @@map("exam_products")
}

model CommerceCartItem {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  productType   ProductType @map("product_type")
  productId     String      @map("product_id") @db.Uuid
  titleSnapshot String      @map("title_snapshot") @db.VarChar(255)
  unitPrice     Int         @map("unit_price")
  quantity      Int         @default(1)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productType, productId])
  @@index([userId])
  @@index([productType, productId])
  @@map("commerce_cart_items")
}

model CommerceOrder {
  id               String              @id @default(uuid()) @db.Uuid
  userId           String              @map("user_id") @db.Uuid
  status           CommerceOrderStatus @default(PENDING_PAYMENT)
  totalAmount      Int                 @map("total_amount")
  paymentProvider  String?             @map("payment_provider") @db.VarChar(50)
  paymentReference String?             @map("payment_reference") @db.VarChar(150)
  paidAt           DateTime?           @map("paid_at") @db.Timestamp(6)
  failedAt         DateTime?           @map("failed_at") @db.Timestamp(6)
  expiredAt        DateTime?           @map("expired_at") @db.Timestamp(6)
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.Timestamp(6)

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      CommerceOrderItem[]
  ownerships CommerceOwnership[]

  @@index([userId])
  @@index([status])
  @@index([paymentReference])
  @@map("commerce_orders")
}

model CommerceOrderItem {
  id            String      @id @default(uuid()) @db.Uuid
  orderId       String      @map("order_id") @db.Uuid
  productType   ProductType @map("product_type")
  productId     String      @map("product_id") @db.Uuid
  titleSnapshot String      @map("title_snapshot") @db.VarChar(255)
  priceAmount   Int         @map("price_amount")
  quantity      Int         @default(1)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamp(6)

  order CommerceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productType, productId])
  @@map("commerce_order_items")
}

model CommerceOwnership {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  orderId     String      @map("order_id") @db.Uuid
  productType ProductType @map("product_type")
  productId   String      @map("product_id") @db.Uuid
  grantedAt   DateTime    @map("granted_at") @db.Timestamp(6)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamp(6)

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  order CommerceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([userId, productType, productId])
  @@index([orderId])
  @@index([productType, productId])
  @@map("commerce_ownerships")
}

enum UserRole {
  USER
  CREATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum CreatorApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductType {
  EXAM
  MENTORING_PACKAGE
}

enum ExamLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ExamDraftStatus {
  DRAFT
  IN_REVIEW
  NEEDS_REVISION
  PUBLISHED
}

enum ExamVersionStatus {
  DRAFT
  IN_REVIEW
  REJECTED
  PUBLISHED
}

enum QuestionCorrectOption {
  A
  B
  C
  D
}

enum ExamReviewAction {
  SUBMITTED
  APPROVED
  REJECTED
}

enum CommerceOrderStatus {
  PENDING_PAYMENT
  PAID
  FAILED
  EXPIRED
}
